body {
    margin: 0;
    font-family: Arial;
    text-align: center;
    background: linear-gradient(to right, #74ebd5, #ACB6E5);
}

h1 {
    padding: 20px;
    color: white;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    padding: 20px;
}

.gallery img {
    width: 200px;
    height: 200px;
    border-radius: 10px;
    transition: transform 0.5s, box-shadow 0.5s;
}

/* Hover Effect */
.gallery img:hover {
    transform: scale(1.1);
    box-shadow: 0 0 20px black;
}
