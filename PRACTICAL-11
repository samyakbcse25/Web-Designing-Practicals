<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Practical 11 — HTML5 APIs</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #07080d;
      --surface:   rgba(255,255,255,0.04);
      --border:    rgba(255,255,255,0.08);
      --border-hi: rgba(99,202,183,0.5);
      --accent:    #63cab7;
      --accent2:   #e8a44a;
      --accent3:   #c678dd;
      --text:      #e8eaf0;
      --muted:     #6b7280;
      --danger:    #ef5350;
      --mono:      'DM Mono', monospace;
      --sans:      'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(99,202,183,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,202,183,0.03) 1px, transparent 1px);
      background-size: 48px 48px;
      animation: gridShift 20s linear infinite;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 20% 20%, rgba(99,202,183,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(198,120,221,0.06) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    @keyframes gridShift {
      0%   { background-position: 0 0, 0 0; }
      100% { background-position: 48px 48px, 48px 48px; }
    }

    .wrapper {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    header {
      text-align: center;
      margin-bottom: 56px;
      animation: fadeUp 0.8s ease both;
    }

    .badge {
      display: inline-block;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(99,202,183,0.08);
      border: 1px solid rgba(99,202,183,0.2);
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
    }

    header h1 {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.1;
      background: linear-gradient(135deg, #fff 0%, var(--accent) 60%, var(--accent2) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 14px;
    }

    header p {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.5px;
      line-height: 1.7;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 28px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      animation: fadeUp 0.8s ease both;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 8px;
    }

    .card-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      background: rgba(99,202,183,0.1);
      border: 1px solid rgba(99,202,183,0.2);
      width: 32px; height: 32px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .card h2 {
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #fff;
    }

    .card-desc {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 24px;
      margin-left: 46px;
      line-height: 1.6;
    }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 20px 0;
    }

    /* ── DRAG & DROP ── */
    .dnd-arena {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 16px;
      align-items: start;
    }

    .dnd-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .dnd-box {
      background: rgba(255,255,255,0.02);
      border: 1.5px dashed rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px;
      min-height: 140px;
    }

    .drag-item {
      background: linear-gradient(135deg, rgba(232,164,74,0.15), rgba(232,164,74,0.05));
      border: 1px solid rgba(232,164,74,0.3);
      color: var(--accent2);
      font-family: var(--mono);
      font-size: 12px;
      padding: 8px 14px;
      border-radius: 8px;
      margin-bottom: 8px;
      cursor: grab;
      display: flex;
      align-items: center;
      gap: 8px;
      user-select: none;
    }

    .drag-item .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent2);
      flex-shrink: 0;
    }

    .dnd-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 60px;
      color: var(--muted);
      font-size: 20px;
    }

    .drop-hint {
      font-family: var(--mono);
      font-size: 11px;
      color: rgba(255,255,255,0.15);
      text-align: center;
      margin-top: 30px;
    }

    /* ── GEO ── */
    .geo-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, rgba(99,202,183,0.15), rgba(99,202,183,0.05));
      border: 1px solid rgba(99,202,183,0.3);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 1px;
      padding: 11px 22px;
      border-radius: 10px;
      cursor: pointer;
    }

    .geo-btn svg { width: 14px; height: 14px; }

    .output-box {
      margin-top: 16px;
      background: rgba(0,0,0,0.3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 18px;
      font-family: var(--mono);
      font-size: 12.5px;
      line-height: 2;
      color: var(--muted);
      min-height: 52px;
    }

    /* ── STORAGE ── */
    .storage-inputs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    .input-group { display: flex; flex-direction: column; gap: 6px; }

    .input-group label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .input-group input {
      background: rgba(0,0,0,0.3);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 10px 14px;
      outline: none;
    }

    .input-group input::placeholder { color: rgba(255,255,255,0.15); }

    .btn-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
    }

    .btn {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.8px;
      padding: 9px 16px;
      border-radius: 8px;
      border: 1px solid;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-teal   { background: rgba(99,202,183,0.08);  border-color: rgba(99,202,183,0.25);  color: var(--accent);  }
    .btn-purple { background: rgba(198,120,221,0.08); border-color: rgba(198,120,221,0.25); color: var(--accent3); }
    .btn-amber  { background: rgba(232,164,74,0.08);  border-color: rgba(232,164,74,0.25);  color: var(--accent2); }
    .btn-red    { background: rgba(239,83,80,0.08);   border-color: rgba(239,83,80,0.25);   color: var(--danger);  }

    footer {
      text-align: center;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-top: 20px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .dnd-arena { grid-template-columns: 1fr; }
      .dnd-arrow { padding-top: 0; transform: rotate(90deg); }
      .storage-inputs { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="wrapper">

  <header>
    <div class="badge">Web Designing Lab · N-VSCCS102P</div>
    <h1>HTML5 APIs<br/>Demonstration</h1>
    <p>Practical No. 11 &nbsp;·&nbsp; S. B. Jain Institute of Technology, Management &amp; Research, Nagpur<br/>
    Drag &amp; Drop &nbsp;·&nbsp; Geolocation &nbsp;·&nbsp; Web Storage</p>
  </header>

  <!-- CARD 1: DRAG & DROP -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">01</div>
      <h2>Drag &amp; Drop API</h2>
    </div>
    <p class="card-desc">Drag items from the source panel into the drop zone using the HTML5 Drag and Drop API.</p>
    <div class="divider"></div>

    <div class="dnd-arena">
      <div>
        <div class="dnd-label">Source</div>
        <div class="dnd-box" id="source-box">
          <div class="drag-item" draggable="true" id="item1" ondragstart="dragStart(event)">
            <span class="dot"></span> Component Alpha
          </div>
          <div class="drag-item" draggable="true" id="item2" ondragstart="dragStart(event)">
            <span class="dot"></span> Component Beta
          </div>
          <div class="drag-item" draggable="true" id="item3" ondragstart="dragStart(event)">
            <span class="dot"></span> Component Gamma
          </div>
        </div>
      </div>

      <div class="dnd-arrow">→</div>

      <div>
        <div class="dnd-label">Drop Zone</div>
        <div class="dnd-box" id="drop-zone"
             ondragover="dragOver(event)"
             ondrop="drop(event)">
          <div class="drop-hint" id="drop-hint">drop items here</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CARD 2: GEOLOCATION -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">02</div>
      <h2>Geolocation API</h2>
    </div>
    <p class="card-desc">Retrieves the user's geographical coordinates via <code style="color:var(--accent);font-family:var(--mono);font-size:11px;">navigator.geolocation.getCurrentPosition()</code></p>
    <div class="divider"></div>

    <button class="geo-btn" onclick="getLocation()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
      </svg>
      GET LOCATION
    </button>

    <div class="output-box" id="geo-result">Awaiting request...</div>
  </div>

  <!-- CARD 3: WEB STORAGE -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">03</div>
      <h2>Web Storage API</h2>
    </div>
    <p class="card-desc">Persist key-value pairs client-side using <code style="color:var(--accent);font-family:var(--mono);font-size:11px;">localStorage</code> &amp; <code style="color:var(--accent3);font-family:var(--mono);font-size:11px;">sessionStorage</code></p>
    <div class="divider"></div>

    <div class="storage-inputs">
      <div class="input-group">
        <label>Key</label>
        <input type="text" id="store-key" placeholder="e.g.  username"/>
      </div>
      <div class="input-group">
        <label>Value</label>
        <input type="text" id="store-value" placeholder="e.g.  Samyak"/>
      </div>
    </div>

    <div class="btn-grid">
      <button class="btn btn-teal"   onclick="saveLocal()">  ↓ Save localStorage</button>
      <button class="btn btn-purple" onclick="saveSession()">↓ Save sessionStorage</button>
      <button class="btn btn-teal"   onclick="getLocal()">   ↑ Get localStorage</button>
      <button class="btn btn-purple" onclick="getSession()"> ↑ Get sessionStorage</button>
      <button class="btn btn-amber"  onclick="removeLocal()">✕ Remove (local)</button>
      <button class="btn btn-red"    onclick="clearAll()">   ✕ Clear All</button>
    </div>

    <div class="output-box" id="storage-output">Awaiting operation...</div>
  </div>

  <footer>
    Web Designing Lab (N-VSCCS102P) &nbsp;·&nbsp; Practical No. 11 &nbsp;·&nbsp;
    S. B. Jain Institute of Technology, Management &amp; Research, Nagpur
  </footer>

</div>

<script>

  /* ── DRAG & DROP ── */

  function dragStart(event) {
    event.dataTransfer.setData("text", event.target.id);
  }

  function dragOver(event) {
    event.preventDefault();
  }

  function drop(event) {
    event.preventDefault();
    var id   = event.dataTransfer.getData("text");
    var item = document.getElementById(id);
    var zone = document.getElementById("drop-zone");
    var hint = document.getElementById("drop-hint");
    if (hint) hint.remove();
    zone.appendChild(item);
  }


  /* ── GEOLOCATION ── */

  function getLocation() {
    var output = document.getElementById("geo-result");

    if (!navigator.geolocation) {
      output.innerHTML = "Geolocation not supported by this browser.";
      return;
    }

    output.innerHTML = "Fetching location...";

    navigator.geolocation.getCurrentPosition(
      function(pos) {
        output.innerHTML =
          "Latitude  : " + pos.coords.latitude  + " deg<br>" +
          "Longitude : " + pos.coords.longitude + " deg<br>" +
          "Accuracy  : " + pos.coords.accuracy  + " m";
      },
      function(err) {
        var msg = {
          1: "Permission denied.",
          2: "Position unavailable.",
          3: "Request timed out."
        };
        output.innerHTML = "Error: " + (msg[err.code] || "Unknown error.");
      }
    );
  }


  /* ── WEB STORAGE ── */

  function saveLocal() {
    var k = document.getElementById("store-key").value;
    var v = document.getElementById("store-value").value;
    if (!k) { document.getElementById("storage-output").innerHTML = "Please enter a key."; return; }
    localStorage.setItem(k, v);
    document.getElementById("storage-output").innerHTML = "Saved to localStorage: " + k + " = " + v;
  }

  function saveSession() {
    var k = document.getElementById("store-key").value;
    var v = document.getElementById("store-value").value;
    if (!k) { document.getElementById("storage-output").innerHTML = "Please enter a key."; return; }
    sessionStorage.setItem(k, v);
    document.getElementById("storage-output").innerHTML = "Saved to sessionStorage: " + k + " = " + v;
  }

  function getLocal() {
    var k = document.getElementById("store-key").value;
    if (!k) { document.getElementById("storage-output").innerHTML = "Please enter a key."; return; }
    var v = localStorage.getItem(k);
    document.getElementById("storage-output").innerHTML = v !== null
      ? "localStorage [" + k + "] = " + v
      : "Key not found in localStorage.";
  }

  function getSession() {
    var k = document.getElementById("store-key").value;
    if (!k) { document.getElementById("storage-output").innerHTML = "Please enter a key."; return; }
    var v = sessionStorage.getItem(k);
    document.getElementById("storage-output").innerHTML = v !== null
      ? "sessionStorage [" + k + "] = " + v
      : "Key not found in sessionStorage.";
  }

  function removeLocal() {
    var k = document.getElementById("store-key").value;
    if (!k) { document.getElementById("storage-output").innerHTML = "Please enter a key."; return; }
    localStorage.removeItem(k);
    document.getElementById("storage-output").innerHTML = "Removed from localStorage: " + k;
  }

  function clearAll() {
    localStorage.clear();
    sessionStorage.clear();
    document.getElementById("storage-output").innerHTML = "All storage cleared.";
  }

</script>
</body>
</html>
