<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Practical 11 — HTML5 APIs</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #07080d;
      --surface:   rgba(255,255,255,0.04);
      --border:    rgba(255,255,255,0.08);
      --border-hi: rgba(99,202,183,0.5);
      --accent:    #63cab7;
      --accent2:   #e8a44a;
      --accent3:   #c678dd;
      --text:      #e8eaf0;
      --muted:     #6b7280;
      --danger:    #ef5350;
      --success:   #63cab7;
      --mono:      'DM Mono', monospace;
      --sans:      'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── ANIMATED GRID BACKGROUND ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(99,202,183,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,202,183,0.03) 1px, transparent 1px);
      background-size: 48px 48px;
      animation: gridShift 20s linear infinite;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 20% 20%, rgba(99,202,183,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(198,120,221,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 40% 30% at 60% 10%, rgba(232,164,74,0.05) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    @keyframes gridShift {
      0%   { background-position: 0 0, 0 0; }
      100% { background-position: 48px 48px, 48px 48px; }
    }

    /* ── LAYOUT ── */
    .wrapper {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    /* ── HEADER ── */
    header {
      text-align: center;
      margin-bottom: 56px;
      animation: fadeUp 0.8s ease both;
    }

    .badge {
      display: inline-block;
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(99,202,183,0.08);
      border: 1px solid rgba(99,202,183,0.2);
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
    }

    header h1 {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.1;
      background: linear-gradient(135deg, #fff 0%, var(--accent) 60%, var(--accent2) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 14px;
    }

    header p {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.5px;
      line-height: 1.7;
    }

    /* ── API CARDS ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 28px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
      animation: fadeUp 0.8s ease both;
    }

    .card:hover {
      border-color: var(--border-hi);
      transform: translateY(-2px);
      box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    }

    .card:nth-child(1) { animation-delay: 0.1s; }
    .card:nth-child(2) { animation-delay: 0.25s; }
    .card:nth-child(3) { animation-delay: 0.4s; }

    .card-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 8px;
    }

    .card-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      background: rgba(99,202,183,0.1);
      border: 1px solid rgba(99,202,183,0.2);
      width: 32px; height: 32px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .card h2 {
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #fff;
    }

    .card-desc {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 24px;
      margin-left: 46px;
      line-height: 1.6;
    }

    /* ── DIVIDER ── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 20px 0;
    }

    /* ── DRAG & DROP ── */
    .dnd-arena {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 16px;
      align-items: start;
    }

    .dnd-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .dnd-box {
      background: rgba(255,255,255,0.02);
      border: 1.5px dashed rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px;
      min-height: 140px;
      transition: border-color 0.2s, background 0.2s;
    }

    .dnd-box.over {
      border-color: var(--accent);
      background: rgba(99,202,183,0.06);
      box-shadow: inset 0 0 20px rgba(99,202,183,0.05);
    }

    .drag-item {
      background: linear-gradient(135deg, rgba(232,164,74,0.15), rgba(232,164,74,0.05));
      border: 1px solid rgba(232,164,74,0.3);
      color: var(--accent2);
      font-family: var(--mono);
      font-size: 12px;
      padding: 8px 14px;
      border-radius: 8px;
      margin-bottom: 8px;
      cursor: grab;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      user-select: none;
    }

    .drag-item:hover {
      transform: translateX(3px);
      box-shadow: 0 4px 16px rgba(232,164,74,0.15);
    }

    .drag-item:active { cursor: grabbing; opacity: 0.7; }

    .drag-item .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent2);
      flex-shrink: 0;
    }

    .dnd-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 60px;
      color: var(--muted);
      font-size: 20px;
    }

    .drop-hint {
      font-family: var(--mono);
      font-size: 11px;
      color: rgba(255,255,255,0.15);
      text-align: center;
      margin-top: 30px;
    }

    /* ── GEO ── */
    .geo-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, rgba(99,202,183,0.15), rgba(99,202,183,0.05));
      border: 1px solid rgba(99,202,183,0.3);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 1px;
      padding: 11px 22px;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .geo-btn:hover {
      background: rgba(99,202,183,0.12);
      border-color: var(--accent);
      box-shadow: 0 0 24px rgba(99,202,183,0.15);
      transform: translateY(-1px);
    }

    .geo-btn svg { width: 14px; height: 14px; }

    .geo-btn.loading { animation: pulse 1.2s ease infinite; }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.5; }
    }

    .output-box {
      margin-top: 16px;
      background: rgba(0,0,0,0.3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 18px;
      font-family: var(--mono);
      font-size: 12.5px;
      line-height: 2;
      color: var(--muted);
      min-height: 52px;
      transition: border-color 0.3s;
    }

    .output-box.has-data {
      border-color: rgba(99,202,183,0.25);
      color: var(--text);
    }

    .output-box .key { color: var(--muted); }
    .output-box .val { color: var(--accent); font-weight: 500; }
    .output-box .err { color: var(--danger); }

    /* ── STORAGE ── */
    .storage-inputs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    .input-group { display: flex; flex-direction: column; gap: 6px; }

    .input-group label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
    }

    .input-group input {
      background: rgba(0,0,0,0.3);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 10px 14px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input:focus {
      border-color: rgba(99,202,183,0.4);
      box-shadow: 0 0 0 3px rgba(99,202,183,0.06);
    }

    .input-group input::placeholder { color: rgba(255,255,255,0.15); }

    .btn-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
    }

    .btn {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.8px;
      padding: 9px 16px;
      border-radius: 8px;
      border: 1px solid;
      cursor: pointer;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-teal {
      background: rgba(99,202,183,0.08);
      border-color: rgba(99,202,183,0.25);
      color: var(--accent);
    }
    .btn-teal:hover {
      background: rgba(99,202,183,0.14);
      border-color: var(--accent);
      box-shadow: 0 0 14px rgba(99,202,183,0.1);
    }

    .btn-purple {
      background: rgba(198,120,221,0.08);
      border-color: rgba(198,120,221,0.25);
      color: var(--accent3);
    }
    .btn-purple:hover {
      background: rgba(198,120,221,0.14);
      border-color: var(--accent3);
    }

    .btn-amber {
      background: rgba(232,164,74,0.08);
      border-color: rgba(232,164,74,0.25);
      color: var(--accent2);
    }
    .btn-amber:hover {
      background: rgba(232,164,74,0.14);
      border-color: var(--accent2);
    }

    .btn-red {
      background: rgba(239,83,80,0.08);
      border-color: rgba(239,83,80,0.25);
      color: var(--danger);
    }
    .btn-red:hover {
      background: rgba(239,83,80,0.14);
      border-color: var(--danger);
    }

    /* ── CONCLUSION & Q&A ── */
    .info-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 28px;
      backdrop-filter: blur(12px);
      animation: fadeUp 0.8s ease 0.55s both;
    }

    .info-card h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .info-card h2::before {
      content: '';
      display: block;
      width: 3px;
      height: 18px;
      border-radius: 2px;
      background: var(--accent);
      flex-shrink: 0;
    }

    .conclusion-text {
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.9;
      color: #9ca3af;
    }

    .conclusion-text strong { color: var(--accent); font-weight: 500; }

    /* Q&A */
    .qa-list { display: flex; flex-direction: column; gap: 20px; }

    .qa-item {}

    .qa-q {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--accent2);
      margin-bottom: 7px;
      display: flex;
      gap: 8px;
    }

    .qa-q .qnum {
      background: rgba(232,164,74,0.12);
      border: 1px solid rgba(232,164,74,0.2);
      border-radius: 5px;
      padding: 1px 8px;
      font-size: 10px;
      flex-shrink: 0;
      display: flex; align-items: center;
    }

    .qa-a {
      font-family: var(--mono);
      font-size: 12.5px;
      color: #9ca3af;
      line-height: 1.85;
      padding-left: 16px;
      border-left: 2px solid rgba(99,202,183,0.2);
    }

    .qa-a strong { color: var(--accent); font-weight: 500; }

    .code-snip {
      display: block;
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: var(--mono);
      font-size: 11.5px;
      color: #a8c7fa;
      margin-top: 10px;
      line-height: 1.8;
      overflow-x: auto;
    }

    .code-snip .kw  { color: #c678dd; }
    .code-snip .fn  { color: #61afef; }
    .code-snip .str { color: #98c379; }
    .code-snip .cm  { color: #5c6370; font-style: italic; }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-top: 20px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      animation: fadeUp 0.8s ease 0.7s both;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .dnd-arena { grid-template-columns: 1fr; }
      .dnd-arrow { padding-top: 0; transform: rotate(90deg); }
      .storage-inputs { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- HEADER -->
  <header>
    <div class="badge">Web Designing Lab · N-VSCCS102P</div>
    <h1>HTML5 APIs<br/>Demonstration</h1>
    <p>Practical No. 11 &nbsp;·&nbsp; S. B. Jain Institute of Technology, Management &amp; Research, Nagpur<br/>
    Drag &amp; Drop &nbsp;·&nbsp; Geolocation &nbsp;·&nbsp; Web Storage</p>
  </header>

  <!-- ════════════════ CARD 1: DRAG & DROP ════════════════ -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">01</div>
      <h2>Drag &amp; Drop API</h2>
    </div>
    <p class="card-desc">Drag items from the source panel into the drop zone using the HTML5 Drag and Drop API.</p>
    <div class="divider"></div>

    <div class="dnd-arena">
      <!-- Source -->
      <div>
        <div class="dnd-label">Source</div>
        <div class="dnd-box" id="source-box">
          <div class="drag-item" draggable="true" ondragstart="dragStart(event)" id="item1">
            <span class="dot"></span> Component Alpha
          </div>
          <div class="drag-item" draggable="true" ondragstart="dragStart(event)" id="item2">
            <span class="dot"></span> Component Beta
          </div>
          <div class="drag-item" draggable="true" ondragstart="dragStart(event)" id="item3">
            <span class="dot"></span> Component Gamma
          </div>
        </div>
      </div>

      <!-- Arrow -->
      <div class="dnd-arrow">→</div>

      <!-- Drop Zone -->
      <div>
        <div class="dnd-label">Drop Zone</div>
        <div class="dnd-box" id="drop-zone"
             ondragover="dragOver(event)"
             ondrop="drop(event)"
             ondragleave="dragLeave(event)">
          <div class="drop-hint">drop items here</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════════════ CARD 2: GEOLOCATION ════════════════ -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">02</div>
      <h2>Geolocation API</h2>
    </div>
    <p class="card-desc">Retrieves the user's geographical coordinates via <code style="color:var(--accent);font-family:var(--mono);font-size:11px;">navigator.geolocation.getCurrentPosition()</code></p>
    <div class="divider"></div>

    <button class="geo-btn" id="geo-btn" onclick="getLocation()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
      </svg>
      GET LOCATION
    </button>

    <div class="output-box" id="geo-result">Awaiting request...</div>
  </div>

  <!-- ════════════════ CARD 3: WEB STORAGE ════════════════ -->
  <div class="card">
    <div class="card-header">
      <div class="card-num">03</div>
      <h2>Web Storage API</h2>
    </div>
    <p class="card-desc">Persist key-value pairs client-side using <code style="color:var(--accent);font-family:var(--mono);font-size:11px;">localStorage</code> &amp; <code style="color:var(--accent3);font-family:var(--mono);font-size:11px;">sessionStorage</code></p>
    <div class="divider"></div>

    <div class="storage-inputs">
      <div class="input-group">
        <label>Key</label>
        <input type="text" id="store-key" placeholder="e.g.  username"/>
      </div>
      <div class="input-group">
        <label>Value</label>
        <input type="text" id="store-value" placeholder="e.g.  Samyak"/>
      </div>
    </div>

    <div class="btn-grid">
      <button class="btn btn-teal"   onclick="saveLocal()">   ↓ Save localStorage</button>
      <button class="btn btn-purple" onclick="saveSession()"> ↓ Save sessionStorage</button>
      <button class="btn btn-teal"   onclick="getLocal()">    ↑ Get localStorage</button>
      <button class="btn btn-purple" onclick="getSession()">  ↑ Get sessionStorage</button>
      <button class="btn btn-amber"  onclick="removeLocal()"> ✕ Remove (local)</button>
      <button class="btn btn-red"    onclick="clearAll()">    ✕ Clear All</button>
    </div>

    <div class="output-box" id="storage-output">Awaiting operation...</div>
  </div>
 
  <!-- FOOTER -->
  <footer>
    Web Designing Lab (N-VSCCS102P) &nbsp;·&nbsp; Practical No. 11 &nbsp;·&nbsp;
    S. B. Jain Institute of Technology, Management &amp; Research, Nagpur
  </footer>

</div>

<!-- ════════════════ JAVASCRIPT ════════════════ -->
<script>

  /* ───── DRAG & DROP ───── */

  function dragStart(event) {
    event.dataTransfer.setData("text/plain", event.target.id);
    event.dataTransfer.effectAllowed = "move";
  }

  function dragOver(event) {
    event.preventDefault();
    event.dataTransfer.dropEffect = "move";
    document.getElementById("drop-zone").classList.add("over");
  }

  function dragLeave() {
    document.getElementById("drop-zone").classList.remove("over");
  }

  function drop(event) {
    event.preventDefault();
    var id = event.dataTransfer.getData("text/plain");
    var el = document.getElementById(id);
    var zone = document.getElementById("drop-zone");
    var hint = zone.querySelector(".drop-hint");
    if (hint) hint.remove();
    zone.appendChild(el);
    zone.classList.remove("over");
  }


  /* ───── GEOLOCATION ───── */

  function getLocation() {
    var output = document.getElementById("geo-result");
    var btn    = document.getElementById("geo-btn");

    if (!navigator.geolocation) {
      output.className = "output-box has-data";
      output.innerHTML = '<span class="err">✕ Geolocation is not supported by this browser.</span>';
      return;
    }

    output.className = "output-box";
    output.innerHTML = "Requesting permission...";
    btn.classList.add("loading");
    btn.disabled = true;

    navigator.geolocation.getCurrentPosition(
      function(pos) {
        btn.classList.remove("loading");
        btn.disabled = false;
        output.className = "output-box has-data";
        output.innerHTML =
          '<span class="key">Latitude &nbsp; : </span><span class="val">' + pos.coords.latitude  + '°</span><br>' +
          '<span class="key">Longitude  : </span><span class="val">' + pos.coords.longitude + '°</span><br>' +
          '<span class="key">Accuracy   : </span><span class="val">' + pos.coords.accuracy  + ' m</span>';
      },
      function(err) {
        btn.classList.remove("loading");
        btn.disabled = false;
        output.className = "output-box has-data";
        var msg = {
          1: "Permission denied by user.",
          2: "Position information is unavailable.",
          3: "Request timed out."
        }[err.code] || "Unknown error occurred.";
        output.innerHTML = '<span class="err">✕ ' + msg + '</span>';
      }
    );
  }


  /* ───── WEB STORAGE ───── */

  function out(html) {
    var el = document.getElementById("storage-output");
    el.className = "output-box has-data";
    el.innerHTML = html;
  }

  function inputs() {
    return {
      k: document.getElementById("store-key").value.trim(),
      v: document.getElementById("store-value").value.trim()
    };
  }

  function saveLocal() {
    var i = inputs();
    if (!i.k) { out('<span class="err">✕ Key field is empty.</span>'); return; }
    localStorage.setItem(i.k, i.v);
    out('<span class="key">localStorage</span>[<span class="val">"' + i.k + '"</span>] = <span class="val">"' + i.v + '"</span> &nbsp;·&nbsp; saved.');
  }

  function saveSession() {
    var i = inputs();
    if (!i.k) { out('<span class="err">✕ Key field is empty.</span>'); return; }
    sessionStorage.setItem(i.k, i.v);
    out('<span class="key">sessionStorage</span>[<span class="val">"' + i.k + '"</span>] = <span class="val">"' + i.v + '"</span> &nbsp;·&nbsp; saved.');
  }

  function getLocal() {
    var i = inputs();
    if (!i.k) { out('<span class="err">✕ Key field is empty.</span>'); return; }
    var r = localStorage.getItem(i.k);
    if (r !== null)
      out('<span class="key">localStorage</span>[<span class="val">"' + i.k + '"</span>] → <span class="val">"' + r + '"</span>');
    else
      out('<span class="err">✕ Key "' + i.k + '" not found in localStorage.</span>');
  }

  function getSession() {
    var i = inputs();
    if (!i.k) { out('<span class="err">✕ Key field is empty.</span>'); return; }
    var r = sessionStorage.getItem(i.k);
    if (r !== null)
      out('<span class="key">sessionStorage</span>[<span class="val">"' + i.k + '"</span>] → <span class="val">"' + r + '"</span>');
    else
      out('<span class="err">✕ Key "' + i.k + '" not found in sessionStorage.</span>');
  }

  function removeLocal() {
    var i = inputs();
    if (!i.k) { out('<span class="err">✕ Key field is empty.</span>'); return; }
    localStorage.removeItem(i.k);
    out('Key <span class="val">"' + i.k + '"</span> removed from localStorage.');
  }

  function clearAll() {
    localStorage.clear();
    sessionStorage.clear();
    out('All localStorage and sessionStorage entries cleared.');
  }

</script>
